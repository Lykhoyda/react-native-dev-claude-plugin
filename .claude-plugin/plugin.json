{
  "name": "rn-dev-agent",
  "version": "0.15.0",
  "description": "AI agent that fully tests React Native features on simulator/emulator — navigates the app, verifies UI, walks user flows, and confirms internal state.",
  "author": {
    "name": "Anton Lykhoyda",
    "url": "https://github.com/Lykhoyda"
  },
  "homepage": "https://github.com/Lykhoyda/rn-dev-agent",
  "repository": "https://github.com/Lykhoyda/rn-dev-agent",
  "license": "MIT",
  "category": "development",
  "keywords": [
    "react-native",
    "expo",
    "testing",
    "debugging",
    "simulator",
    "emulator",
    "cdp",
    "maestro"
  ],
  "skills": [
    "./skills/rn-device-control",
    "./skills/rn-testing",
    "./skills/rn-debugging",
    "./skills/rn-best-practices"
  ],
  "agents": [
    "./agents/rn-tester.md",
    "./agents/rn-debugger.md",
    "./agents/rn-code-explorer.md",
    "./agents/rn-code-architect.md",
    "./agents/rn-code-reviewer.md"
  ],
  "commands": [
    "./commands/test-feature.md",
    "./commands/debug-screen.md",
    "./commands/check-env.md",
    "./commands/build-and-test.md",
    "./commands/rn-feature-dev.md",
    "./commands/proof-capture.md",
    "./commands/rn-agent-compact.md",
    "./commands/rn-agent-export.md",
    "./commands/rn-agent-import.md",
    "./commands/rn-agent-health.md",
    "./commands/nav-graph.md",
    "./commands/send-feedback.md"
  ],
  "userConfig": {
    "RN_METRO_PORT": {
      "description": "Default Metro bundler port (leave empty for auto-detect: 8081, 8082, 19000, 19006)",
      "type": "text",
      "required": false
    },
    "RN_PREFERRED_PLATFORM": {
      "description": "Preferred target platform for CDP connection",
      "type": "select",
      "required": false,
      "options": ["auto", "ios", "android"]
    },
    "RN_DEV_AGENT_LOG_LEVEL": {
      "description": "MCP server log verbosity",
      "type": "select",
      "required": false,
      "options": ["warn", "info", "debug", "error"]
    }
  },
  "mcpServers": {
    "rn-dev-agent-cdp": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/cdp-bridge/dist/index.js"]
    }
  }
}
