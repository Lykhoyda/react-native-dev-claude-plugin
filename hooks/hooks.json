{
  "description": "Detect React Native projects on session start and hint available commands",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-rn-project.sh"
          }
        ]
      }
    ]
  }
}
